# Q.I.A Event Indexer
# Syncs CompetitionLobby contract events → Supabase

QIE_TESTNET_RPC=https://rpc1testnet.qie.digital/
LOBBY_CONTRACT_ADDRESS=0x...
LEADERBOARD_CONTRACT_ADDRESS=0x...

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key (NOT anon key)

# Block to start indexing from (set to contract deploy block)
START_BLOCK=0

# Polling interval in ms (QIE ~3s blocks → 4000ms is safe)
POLL_INTERVAL=4000
